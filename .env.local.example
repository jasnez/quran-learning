# Static-only app. Quran sadržaj se servira iz src/data/, audio s everyayah.com.
# Nije potreban backend — Vercel deploy radi bez ikakvih env varijabli.
#
# Opciono (za audio):
# NEXT_PUBLIC_AUDIO_CDN_URL=https://your-cdn.example/audio   # ako budeš imao vlastiti audio CDN
# NEXT_PUBLIC_AUDIO_VIA_PROXY=1                              # ako CDN ima CORS problem (koristi /api/audio)
