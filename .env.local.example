# Supabase (copy to .env.local for dev; for production set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=https://xivwzevkvpjwtgjvujyr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Required for database seeding (npm run seed). Use service_role key, not anon.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Audio CDN (Supabase Storage public URL for audio bucket – no trailing slash)
# Dev: set in .env.local. Production: set in Vercel env (same value).
# NEXT_PUBLIC_AUDIO_CDN_URL=https://xivwzevkvpjwtgjvujyr.supabase.co/storage/v1/object/public/audio

# If Supabase has no CORS in dashboard and audio fails with CORS error, set to 1 to stream audio via /api/audio (same-origin, no CORS needed).
# NEXT_PUBLIC_AUDIO_VIA_PROXY=1
